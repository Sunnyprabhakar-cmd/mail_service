NODE_ENV=production
PORT=10000

DATABASE_URL=<from-render-postgres-connection-string>
DATABASE_SSL=auto
DATABASE_SSL_REJECT_UNAUTHORIZED=false
REDIS_URL=<from-render-redis-connection-string>

MAILGUN_API_KEY=<your-mailgun-api-key>
MAILGUN_DOMAIN=<your-mailgun-domain>
MAILGUN_FROM=<your-from-address>

WEBHOOK_SECRET=<your-webhook-secret>
CRON_DELETE_AFTER_DAYS=30

CAMPAIGN_TOKEN_SECRET=change_this_campaign_secret
CAMPAIGN_TOKEN_EXPIRES_IN=7d

EMAIL_WORKER_CONCURRENCY=40
EMAIL_RATE_LIMIT_MAX=80
EMAIL_RATE_LIMIT_DURATION_MS=1000
RUN_WORKER_IN_API=false
WORKER_HTTP_PORT=8080

# Migration safety for cloud deploys (startup/network delays)
MIGRATION_MAX_RETRIES=12
MIGRATION_RETRY_DELAY_MS=5000
ALLOW_MIGRATION_FAILURE=false
